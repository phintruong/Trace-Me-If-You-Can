# ------------------------
# Database (SQLite default)
# ------------------------
# Use SQLite local file under outputs/fraud_backend.db
DB_MODE=sqlite
DB_CONN_STRING=

# ------------------------
# Model configuration
# ------------------------
# Option 1: use local model file (recommended for hackathon)
# After training, the model is usually written to "outputs/model.pkl"
MODEL_PATH=outputs/model.pkl

# Option 2: use remote scoring service instead of MODEL_PATH
#MODEL_URL=https://your-model-service.example.com

# Risk threshold for flags; 0.7 is a good default
RISK_THRESHOLD=0.7

# ------------------------
# Watsonx.ai (AI explanations)
# ------------------------
# Get these from your IBM Cloud Watsonx project / space.
# DO NOT commit real values to Git; keep them only in your local .env.

WATSONX_APIKEY=replace_with_your_watsonx_api_key
WATSONX_PROJECT_ID=replace_with_your_watsonx_project_id

# Optional: model + endpoint override
WATSONX_MODEL_ID=granite-13b-instruct
#WATSONX_URL=https://us-south.ml.cloud.ibm.com/ml/v1

# ------------------------
# Logging and pipeline
# ------------------------
LOG_LEVEL=INFO

# Where outputs (DB, parquet, model) are stored; defaults to project outputs/
#OUTPUT_DIR=outputs

# Inference pipeline dataset source: "ibm" or path to CSV
DATASET_SOURCE=ibm

# Reserved for future cache TTL (currently unused)
CACHE_TTL_SECONDS=86400

